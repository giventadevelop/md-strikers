# Test Environment Variables File
# This file tests various edge cases for the env var scripts

# Basic key=value
NEXT_PUBLIC_TENANT_ID=test_tenant

# With spaces around equals
NEXT_PUBLIC_API_BASE_URL = https://api.example.com

# Quoted values
DATABASE_URL="postgresql://user:pass@localhost:5432/db"
API_JWT_USER='testuser'

# Inline comments
STRIPE_KEY=sk_test_12345 # This is the test key
NODE_ENV=development  # Development environment

# Empty value
EMPTY_VAR=

# Value with equals sign
CONNECTION_STRING=Server=localhost;Database=test;User=admin

# Comment lines should be ignored
# IGNORED_VAR=should_not_appear

# Multi-word values
APP_NAME="My Cool App"
DESCRIPTION='This is a test application'

# Values with special characters
PASSWORD=P@ssw0rd!#Special
URL_WITH_QUERY=https://example.com?param=value&other=123

# Trailing whitespace should be trimmed
TRIMMED_VAR=value_with_spaces

# Leading whitespace
  LEADING_SPACE=indented_value

# Empty lines should be skipped


# Values with # inside quotes should work
QUOTED_HASH="value with # inside"
ANOTHER_QUOTED='also # works'
